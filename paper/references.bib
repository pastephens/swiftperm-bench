@article{ReyStephensLaura2017,
  author    = {Rey, Sergio J. and Stephens, Philip and Laura, Jason},
  title     = {An evaluation of sampling and full enumeration strategies for
               {Fisher Jenks} classification in big data settings},
  journal   = {Transactions in {GIS}},
  volume    = {21},
  number    = {4},
  pages     = {796--810},
  year      = {2017},
  issn      = {1467-9671},
  doi       = {10.1111/tgis.12236},
  url       = {http://dx.doi.org/10.1111/tgis.12236},
  abstract  = {Large data contexts present a number of challenges to optimal
               choropleth map classifiers. Application of optimal classifiers
               to a sample of the attribute space is one proposed solution.
               The properties of alternative sampling-based classification
               methods are examined through a series of Monte Carlo
               simulations. The impacts of spatial autocorrelation, number of
               desired classes, and form of sampling are shown to have
               significant impacts on the accuracy of map classifications.
               Tradeoffs between improved speed of the sampling approaches
               and loss of accuracy are also considered. The results suggest
               the possibility of guiding the choice of classification scheme
               as a function of the properties of large data sets.},
}

